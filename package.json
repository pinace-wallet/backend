{
  "name": "pinace-backend",
  "version": "0.1.0",
  "description": "Pinace backend — modular Fastify REST API and background event indexer",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run generate:openapi",
    "dev": "tsx watch src/index.ts",
    "test": "vitest --run",
    "start": "node dist/index.js",
    "generate:openapi": "tsx src/scripts/generate-openapi.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/swagger": "^9.7.0",
    "@mysten/sui": "^2.17.0",
    "@pinace/contracts-sdk": "file:../contracts-sdk",
    "@prisma/client": "^5.14.0",
    "fastify": "^5.3.2",
    "fastify-type-provider-zod": "^4.0.2",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "fast-check": "^3.23.1",
    "prisma": "^5.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
